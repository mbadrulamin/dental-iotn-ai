# Application
APP_NAME=Dental IOTN AI Platform
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://admin:dev_password@localhost:5432/dental_iotn

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Models
MODELS_DIR=./models
DEVICE=cuda  # cuda or cpu

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
